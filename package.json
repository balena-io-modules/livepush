    "@types/lodash": "^4.17.24",
    "@types/md5": "^2.3.6",
    "@types/minimatch": "^3.0.5",
    "@types/mocha": "^10.0.10",
    "@types/mz": "^0.0.32",
    "@types/shell-escape": "^0.2.3",
    "@types/shell-quote": "^1.7.5",
    "@types/sinon": "^5.0.7",
    "@types/tar-fs": "^1.16.3",
    "@types/tar-stream": "^1.6.7",
    "chai": "^4.5.0",
    "chai-as-promised": "^7.1.2",
    "husky": "^3.1.0",
    "lint-staged": "^8.2.1",
    "mocha": "^11.7.5",
    "nyc": "^13.3.0",
    "require-npm4-to-publish": "^1.0.0",
    "resin-lint": "^3.3.1",
    "sinon": "^6.3.5",
    "source-map-support": "^0.5.21",
    "tar-fs": "^2.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "docker-file-parser": "^1.0.7",
    "dockerode": "^2.5.8",
    "lodash": "^4.17.23",
    "minimatch": "^3.1.5",
    "mz": "^2.7.0",
    "node-watch": "^0.7.4",
    "shell-escape": "^0.2.0",
    "shell-quote": "^1.8.3",
