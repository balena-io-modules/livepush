{
	"compilerOptions": {
		"module": "commonjs",
		"target": "es6",
		"outDir": "build",
		"esModuleInterop": true,
		"preserveConstEnums": true,
		"declaration": true,
		"pretty": true,
		"sourceMap": true,
		"skipLibCheck": true
	},
	"include": [
		"typings/**/*.ts",
		"lib/**/*.ts",
		"test/**/*.ts"
	]
}
